@import url('https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,100..900;1,100..900&display=swap');

/* General Styles */
.navbar-shadow {
  background-color: #a9c3e6;
  padding: 0 5%;
  height: 100px;
}

/* Sliding Menu */
.side-menu {
  position: fixed;
  top: 0;
  right: -100%;
  width: 100%;
  height: 100%;
  background-color: #f2f1f0;
  z-index: 1050;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: right 0.5s ease-in-out;
  overflow-y: auto;
}





/* Header Mobile Container */
.header-mobile {
  position: fixed;
  top: 0;
  width: 100%;
  height: 100px;
  /* Adjust based on the header height */
  background-color: #a9c3e6;
  z-index: 1050;
  display: flex;
  align-items: center;
}

.header-title {
  font-size: 26px;
  font-weight: 500;
  font-family: 'Raleway', serif !important;
  color: #fee1be;
  margin: 0;
}


.offcanvas.side-menu {
  transform: translateX(100%); /* Start off-screen to the right */
  transition: transform 0.5s ease-in-out; /* Smooth transition */
}

/* When Offcanvas is shown */
.offcanvas.side-menu.show {
  transform: translateX(0); /* Slide into view */
}

/* Optional: Add custom styles for the overlay */
.offcanvas-backdrop {
  transition: opacity 0.5s ease-in-out;
}

.side-menu .nav-link {
  font-size: 24px;
  margin: 15px 0;
  color: #333;
  text-decoration: none;
  transition: color 0.2s;
}